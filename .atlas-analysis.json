  "keyFeatures": [
    "Interactive REPL with LLM-powered agents",
    "Server-side LLM proxy architecture",
    "Remote execution environments (Weavers) via Kubernetes",
    "Thread persistence with FTS5 search",
    "Multi-provider LLM support (Anthropic, OpenAI, Vertex AI)",
    "Comprehensive tool system (file operations, bash, web search)",
    "OAuth and magic link authentication",
    "PostHog-style analytics with identity resolution",
    "Crash tracking with symbolication",
    "Feature flags and experimentation framework"
  ],
  "publicApiSurface": [
    "POST /api/threads - Create conversation thread",
    "GET /api/threads/{id} - Get thread by ID",
    "POST /api/weavers - Create remote weaver pod",
    "GET /api/weavers - List weavers",
    "DELETE /api/weavers/{id} - Delete weaver",
    "POST /proxy/{provider}/complete - LLM completion proxy",
    "POST /proxy/{provider}/stream - LLM streaming proxy",
    "POST /auth/login - Authenticate user",
    "POST /auth/device/code - Device code flow",
    "GET /health - Health check",
    "loom - Start interactive REPL",
    "loom new - Create new weaver",
    "loom attach - Attach to weaver",
    "loom weaver ps - List weavers",
    "loom login - Authenticate with server"
  ]
